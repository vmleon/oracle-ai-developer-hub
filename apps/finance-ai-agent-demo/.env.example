# Oracle Database
ORACLE_USER=VECTOR
ORACLE_PASSWORD=VectorPwd_2025
ORACLE_DSN=127.0.0.1:1521/FREEPDB1
ORACLE_ADMIN_PWD=OraclePwd_2025

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Tavily (web search)
TAVILY_API_KEY=tvly-...

# Embeddings
EMBEDDING_MODEL=sentence-transformers/paraphrase-mpnet-base-v2

# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=false
FLASK_PORT=5001

# ── Sprawl Architecture (multi-database mode) ──────────────────────
# Set ARCH_MODE=sprawl to use separate databases instead of Oracle converged.
ARCH_MODE=converged

# PostgreSQL + PostGIS (relational + spatial)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=sprawl
POSTGRES_PASSWORD=sprawl_pwd
POSTGRES_DB=finance

# Neo4j (graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_pwd

# MongoDB (JSON/document)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=finance

# Qdrant (vector search)
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
